# ──────────────────────────────────────────────
# Paymark API – Environment Variables
# ──────────────────────────────────────────────

# ─── Server ───────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── Database (PostgreSQL via Prisma) ─────────
# Connection string for your PostgreSQL database.
# Examples:
#   Local:   postgresql://user:password@localhost:5432/paymark
DATABASE_URL=postgresql://user:password@localhost:5432/paymark

# ─── Auth (JWT) ───────────────────────────────
# Generate strong secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-to-a-random-64-byte-hex-string

# ─── Stripe ───────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_API_VERSION=2025-02-24.acacia
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── Frontend ─────────────────────────────────
# URL of the deployed Next.js frontend (used for CORS and Stripe redirects).
# Local dev: http://localhost:3000
FRONTEND_URL=http://localhost:3000
